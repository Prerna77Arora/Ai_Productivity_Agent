# AI Productivity Agent Environment Configuration
# Copy this file to .env and fill in your actual values

# =================================================================
# REQUIRED: Groq API Configuration
# =================================================================

# Get your API key from: https://console.groq.com/keys
# Free tier includes 100,000 tokens/day
GROQ_API_KEY=your_groq_api_key_here

# =================================================================
# OPTIONAL: Model Configuration
# =================================================================

# Groq model to use (default: llama-3.3-70b-versatile)
# Available models: llama-3.3-70b-versatile, llama-3.1-8b-instant, mixtral-8x7b-32768
GROQ_MODEL=llama-3.3-70b-versatile

# LLM temperature (0.0 = deterministic, 1.0 = creative)
# Recommended: 0.0 for productivity tasks
LLM_TEMPERATURE=0

# Maximum tokens for LLM responses (default: 800)
# Lower values reduce API usage and costs
LLM_MAX_TOKENS=800

# =================================================================
# OPTIONAL: Agent Behavior Configuration
# =================================================================

# Maximum recursion limit for LangGraph agent (default: 25)
# Prevents infinite loops in complex reasoning
AGENT_RECURSION_LIMIT=25

# Maximum tool iterations per request (default: 10)
# Limits how many tools can be called in one conversation
AGENT_MAX_ITERATIONS=10

# =================================================================
# DEVELOPMENT SETTINGS
# =================================================================

# Enable debug logging (uncomment for development)
# PYTHONPATH=.
# LOG_LEVEL=DEBUG

# =================================================================
# SECURITY NOTES
# =================================================================

# 1. Never commit your actual .env file to version control
# 2. Keep your API key secure and private
# 3. Use different keys for development and production
# 4. Monitor your API usage at: https://console.groq.com/
# 5. Upgrade to paid tier for higher limits if needed

# =================================================================
# QUICK SETUP INSTRUCTIONS
# =================================================================

# 1. Copy this file: cp .env.example .env
# 2. Edit .env and add your Groq API key
# 3. Run: streamlit run ui/app.py
# 4. Open browser to: http://localhost:8501

# =================================================================
# TROUBLESHOOTING
# =================================================================

# If you get "Missing required env variable" error:
# - Make sure .env file exists in project root
# - Check that GROQ_API_KEY is set correctly
# - Verify no extra spaces around the API key

# If you get rate limit errors:
# - Wait for daily reset (free tier: 100,000 tokens/day)
# - Consider upgrading to paid tier at https://console.groq.com/
# - Monitor usage in your Groq dashboard

# If you get import errors:
# - Run: pip install -r requirements.txt
# - Activate virtual environment: source venv/bin/activate
# - Check Python version: python --version (should be 3.11+)
